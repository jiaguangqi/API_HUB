# AI API Hub V2 - 环境变量配置
# 复制此文件为 .env 并根据实际情况修改

# JWT 签名密钥（重要：生产环境请更换为随机字符串）
JWT_SECRET=your-secret-key-here

# 服务器配置
# 部署时自动设置为实际服务器IP，本地开发保持localhost
SERVER_IP=localhost

# 端口配置
API_PORT=8080
FRONTEND_PORT=3000

# 数据库路径（可选，默认使用 ./data/api-hub-v2.db）
# DATABASE_PATH=./data/api-hub-v2.db

# 日志级别（可选: debug, info, warn, error）
# LOG_LEVEL=info
